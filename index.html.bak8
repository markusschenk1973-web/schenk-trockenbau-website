<script>
// Project data
let lbProjekte = [];

// NAV
window.addEventListener('scroll',()=>{document.getElementById('nav').classList.toggle('scrolled',window.scrollY>60);});
function toggleMenu(){document.getElementById('mobMenu').classList.toggle('open');}

// HERO REPLAY
function replayHero(e){
  if(e)e.preventDefault();
  window.scrollTo({top:0,behavior:'smooth'});
  setTimeout(()=>{
    const w=window.innerWidth;
    const h=window.innerHeight;
    const isPortrait=h>=w;
    const isTablet=(w>=768&&w<=1100)||(w>=600&&w<=2000&&isPortrait);
    const textAnim=isTablet?'fromLeft':'fromBottom';
    const textStart=isTablet?'translateX(-40px)':'translateY(40px)';
    const photoAnim=isTablet?'fromRight 1.2s':'zoomInSmall 3.5s';
    const photoStart=isTablet?'translateX(80px)':'scale(0.65)';
    const els=['.hero-tag','.hero-h1','.hero-sub','.hero-btn-wrap'].map(s=>document.querySelector(s));
    const r=document.querySelector('.hero-rechts');
    els.forEach(el=>{el.style.animation='none';el.style.opacity='0';el.style.transform=textStart;});
    r.style.animation='none';r.style.opacity='0';r.style.transform=photoStart;
    void document.getElementById('hero').offsetWidth;
    setTimeout(()=>{
      [0.7,0.95,1.2,1.45].forEach((delay,i)=>{els[i].style.animation=`${textAnim} 1s cubic-bezier(0.16,1,0.3,1) ${delay}s forwards`;});
      r.style.animation=`${photoAnim} cubic-bezier(0.25,0.46,0.45,0.94) 0.5s forwards`;
    },50);
  },400);
}

// REFERENZ KARTEN
const refListeEl=document.getElementById('refListe');
const refEmptyEl=document.getElementById('refEmpty');
function escapeHtml(s){return String(s).replace(/[&<>"']/g,c=>({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":"&#39;"}[c]));}
async function ladeReferenzen(){
  try{
    const res=await fetch('projekte.json',{cache:'no-store'});
    if(!res.ok)throw new Error('HTTP '+res.status);
    const daten=await res.json();
    if(!Array.isArray(daten)||daten.length===0){zeigeLeer();return;}
    lbProjekte=daten.map(p=>({titel:p.titel,text:p.text,bilder:Array.isArray(p.bilder)?p.bilder.slice(0,10):[],vorher:!!p.vorher}));
    const html=daten.map((p,i)=>{
      const bilder=Array.isArray(p.bilder)?p.bilder.slice(0,10):[];
      const tag=p.vorher?'<div class="ref-vorher-tag">Vorher / Nachher</div>':'';
      const galerie=bilder.length>0
        ?`<div class="ref-galerie">${bilder.map((b,j)=>`<img src="${escapeHtml(b)}" alt="${escapeHtml(p.titel)} Bild ${j+1}" class="ref-thumb" onclick="openLightbox(${i},${j})">`).join('')}</div>`
        :'';
      return `<div class="ref-karte"><div class="ref-titelbild-wrap"><img src="${escapeHtml(p.titelbild)}" alt="${escapeHtml(p.titel)}" class="ref-titelbild">${tag}</div><div class="ref-info"><div class="ref-titel">${escapeHtml(p.titel)}</div><div class="ref-text">${escapeHtml(p.text)}</div></div>${galerie}</div>`;
    }).join('');
    refListeEl.insertAdjacentHTML('beforeend',html);
  }catch(err){console.error('Fehler beim Laden der Referenzen:',err);zeigeLeer();}
}
function zeigeLeer(){if(refEmptyEl)refEmptyEl.style.display='block';}
ladeReferenzen();

// LIGHTBOX
let lbCurProj=0, lbCurImg=0;

function openLightbox(projIdx,imgIdx){
  const p=lbProjekte[projIdx];
  if(!p||!p.bilder||p.bilder.length===0)return;
  lbCurProj=projIdx;
  lbCurImg=imgIdx||0;
  renderLb();
  document.getElementById('lbOverlay').classList.add('open');
  document.body.style.overflow='hidden';
}

function renderLb(){
  const p=lbProjekte[lbCurProj];
  document.getElementById('lbMainImg').src=p.bilder[lbCurImg];
  document.getElementById('lbTitel').textContent=p.titel;
  document.getElementById('lbText').textContent=p.text;
  document.getElementById('lbCount').textContent=`${lbCurImg+1} / ${p.bilder.length} Fotos`;
  document.getElementById('lbVorherTag').style.display=p.vorher?'block':'none';
  // Thumbnails
  const thumbsEl=document.getElementById('lbThumbs');
  thumbsEl.innerHTML='';
  p.bilder.forEach((img,i)=>{
    const t=document.createElement('img');
    t.src=img; t.className='lb-thumb'+(i===lbCurImg?' aktiv':'');
    t.onclick=()=>{lbCurImg=i;renderLb();};
    thumbsEl.appendChild(t);
  });
}

function lbNav(dir){
  const p=lbProjekte[lbCurProj];
  lbCurImg=(lbCurImg+dir+p.bilder.length)%p.bilder.length;
  renderLb();
}

function closeLb(){
  document.getElementById('lbOverlay').classList.remove('open');
  document.body.style.overflow='';
}

function closeLbIfOutside(e){
  if(e.target===document.getElementById('lbOverlay'))closeLb();
}

// Keyboard navigation
document.addEventListener('keydown',e=>{
  if(!document.getElementById('lbOverlay').classList.contains('open'))return;
  if(e.key==='Escape')closeLb();
  if(e.key==='ArrowLeft')lbNav(-1);
  if(e.key==='ArrowRight')lbNav(1);
});

// FAQ Akkordeon
function faqToggle(btn){
  const item = btn.parentElement;
  const antwort = item.querySelector('.faq-antwort');
  const isOffen = antwort.classList.contains('offen');
  // Close all
  document.querySelectorAll('.faq-antwort').forEach(a=>a.classList.remove('offen'));
  document.querySelectorAll('.faq-frage').forEach(b=>b.classList.remove('offen'));
  // Open clicked if was closed
  if(!isOffen){
    antwort.classList.add('offen');
    btn.classList.add('offen');
  }
}

// REVEAL
const obs=new IntersectionObserver(entries=>{
  entries.forEach(e=>{if(e.isIntersecting){e.target.classList.add('visible');obs.unobserve(e.target);}})},{threshold:0.1});
document.querySelectorAll('.reveal,.reveal-up,.reveal-left').forEach(el=>obs.observe(el));

// Bewertungen Carousel
(function(){
  const track = document.getElementById('bewTrack');
  const dotsEl = document.getElementById('bewDots');
  if(!track) return;
  const cards = track.querySelectorAll('.bew-karte');
  const total = cards.length;
  let visible = window.innerWidth < 700 ? 1 : 3;
  let cur = 0;
  let timer;

  // Build dots
  const steps = Math.ceil(total / visible);
  for(let i=0;i<steps;i++){
    const d=document.createElement('button');
    d.className='bew-dot'+(i===0?' aktiv':'');
    d.onclick=()=>bewGoTo(i*visible);
    dotsEl.appendChild(d);
  }

  function bewGoTo(n){
    const max = total - visible;
    cur = Math.max(0, Math.min(n, max));
    const cardW = cards[0].offsetWidth + 16;
    track.style.transform = `translateX(-${cur * cardW}px)`;
    document.querySelectorAll('.bew-dot').forEach((d,i)=>{
      d.classList.toggle('aktiv', i===Math.floor(cur/visible));
    });
    clearInterval(timer);
    timer = setInterval(()=>bewGoTo(cur+visible >= total ? 0 : cur+1), 5000);
  }

  window.bewSlide = function(dir){
    bewGoTo(cur + dir);
  };

  // Check text truncation and show Weiterlesen
  function checkTruncation(){
    document.querySelectorAll('.bew-text').forEach(el=>{
      const btn=el.closest('.bew-text-wrap').querySelector('.bew-mehr');
      if(el.scrollHeight > el.clientHeight + 4) btn.classList.add('show');
    });
  }
  window.addEventListener('load', checkTruncation);
  timer = setInterval(()=>bewGoTo(cur+1 >= total ? 0 : cur+1), 5000);
})();

function bewToggle(btn, id){
  const el=document.getElementById(id);
  const karte=el.closest('.bew-karte');
  el.classList.toggle('expanded');
  if(el.classList.contains('expanded')){
    btn.textContent='Weniger';
    karte.style.height='auto';
  } else {
    btn.textContent='Weiterlesen';
    karte.style.height='240px';
  }
}

// Legal Modals
function openModal(id){
  const el=document.getElementById('modal-'+id);
  if(el){el.classList.add('open');document.body.style.overflow='hidden';}
}
function closeModal(id){
  const el=document.getElementById('modal-'+id);
  if(el){el.classList.remove('open');document.body.style.overflow='';}
}
function closeModalIfOutside(e,id){
  if(e.target===document.getElementById('modal-'+id))closeModal(id);
}
document.addEventListener('keydown',e=>{
  if(e.key==='Escape'){['impressum','datenschutz'].forEach(id=>closeModal(id));}
});

// CAPTCHA Placeholder
function captchaToggle(){
  const box = document.getElementById('captchaBox');
  const btn = document.getElementById('submitBtn');
  if(box.classList.contains('checked')) return;
  box.classList.add('checking');
  setTimeout(()=>{
    box.classList.remove('checking');
    box.classList.add('checked');
    btn.disabled = false;
    btn.style.opacity = '1';
    btn.style.cursor = 'pointer';
  }, 1200);
}

// Prozess carousel — only active on mobile (≤900px); on desktop all 4 cards are shown in a grid
(function(){
  const track = document.getElementById('prozessTrack');
  const dotsEl = document.getElementById('prozessDots');
  if(!track||!dotsEl) return;
  const karten = track.querySelectorAll('.prozess-karte');
  const total = karten.length;
  let cur = 0, timer;
  const isMobile = ()=>window.matchMedia('(max-width:900px)').matches;

  // Build dots
  karten.forEach((_,i)=>{
    const d = document.createElement('button');
    d.className = 'prozess-dot-m'+(i===0?' aktiv':'');
    d.onclick = ()=>prozessGoTo(i);
    dotsEl.appendChild(d);
  });

  function prozessGoTo(n){
    if(!isMobile()) return;
    cur = (n+total)%total;
    const cardW = track.parentElement.offsetWidth;
    track.style.transform = `translateX(-${cur * cardW}px)`;
    dotsEl.querySelectorAll('.prozess-dot-m').forEach((d,i)=>d.classList.toggle('aktiv',i===cur));
    clearInterval(timer);
    timer = setInterval(()=>prozessGoTo(cur+1), 5000);
  }

  window.prozessNav = function(dir){ prozessGoTo(cur+dir); };

  // Swipe
  let sx=0;
  const vp = document.getElementById('prozessVp');
  vp.addEventListener('touchstart',e=>{sx=e.touches[0].clientX;},{passive:true});
  vp.addEventListener('touchend',e=>{
    const diff=sx-e.changedTouches[0].clientX;
    if(Math.abs(diff)>40) prozessGoTo(cur+(diff>0?1:-1));
  },{passive:true});

  function startAuto(){
    clearInterval(timer);
    if(isMobile()) timer = setInterval(()=>prozessGoTo(cur+1), 5000);
  }
  startAuto();
  window.addEventListener('resize',()=>{
    if(!isMobile()){
      track.style.transform = '';
      cur = 0;
      dotsEl.querySelectorAll('.prozess-dot-m').forEach((d,i)=>d.classList.toggle('aktiv',i===0));
      clearInterval(timer);
    } else {
      startAuto();
    }
  });
})();
</script>

<!-- IMPRESSUM MODAL -->
<div class="legal-overlay" id="modal-impressum" onclick="closeModalIfOutside(event,'impressum')">
  <div class="legal-box">
    <button class="legal-close" onclick="closeModal('impressum')">✕</button>
    <h2>Impressum</h2>
    <div class="legal-content">
      <h3>Angaben gemäß § 5 TMG</h3>
      <p><strong>Schenk Trockenbau</strong><br>
      Markus Schenk<br>
      Im Rübenacher Gesetz 7<br>
      56072 Koblenz</p>

      <h3>Kontakt</h3>
