    <div class="bew-dots" id="bewDots"></div>
    <div class="bew-gesamt reveal">
      <div class="bew-score">
        <span class="bew-score-nr">5.0</span>
        <div>
          <div class="bew-sterne" style="font-size:20px;">★★★★★</div>
          <div style="font-size:13px;color:var(--grau);margin-top:4px;">Basierend auf Google Bewertungen</div>
