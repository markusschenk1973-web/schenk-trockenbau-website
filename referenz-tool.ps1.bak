Add-Type -AssemblyName System.Windows.Forms
Add-Type -AssemblyName System.Drawing

$scriptDir  = Split-Path -Parent $MyInvocation.MyCommand.Path
$jsonPath   = Join-Path $scriptDir "projekte.json"
$bildOrdner = Join-Path $scriptDir "assets_referenzen"

if (-not (Test-Path $bildOrdner)) {
    New-Item -ItemType Directory -Path $bildOrdner | Out-Null
}

function Lade-Projekte {
    if (Test-Path $jsonPath) {
        $raw = Get-Content $jsonPath -Encoding UTF8 -Raw
        if ($raw.Trim() -ne "") { return ($raw | ConvertFrom-Json) }
    }
    return @()
}

function Kopiere-Bild($quellPfad) {
    $dateiName = [System.IO.Path]::GetFileName($quellPfad)
    $zielPfad  = Join-Path $bildOrdner $dateiName
    if (Test-Path $zielPfad) {
        $ext       = [System.IO.Path]::GetExtension($dateiName)
        $name      = [System.IO.Path]::GetFileNameWithoutExtension($dateiName)
        $stamp     = Get-Date -Format "yyyyMMdd_HHmmss"
        $dateiName = "${name}_${stamp}${ext}"
        $zielPfad  = Join-Path $bildOrdner $dateiName
    }
    Copy-Item $quellPfad $zielPfad
    return "assets_referenzen/$dateiName"
}

