#  Events 

$btnTitelbild.Add_Click({
    $dlg = New-Object System.Windows.Forms.OpenFileDialog
    $dlg.Filter = "Bilddateien (*.jpg;*.jpeg;*.png;*.webp)|*.jpg;*.jpeg;*.png;*.webp"
    $dlg.Title  = "Titelbild auswaehlen"
    if ($dlg.ShowDialog() -eq "OK") {
        $script:gewaehlteTitelbild = $dlg.FileName
        $txtTitelbildPfad.Text = [System.IO.Path]::GetFileName($dlg.FileName)
        try {
            $picTitel.Image = [System.Drawing.Image]::FromFile($dlg.FileName)
            $lblTitelVorschau.Visible = $false
        } catch {}
    }
})

$btnGalerieBild.Add_Click({
    if ($script:galeriebilder.Count -ge 10) {
        [System.Windows.Forms.MessageBox]::Show("Maximal 10 Galeriebilder erlaubt.", "Maximum erreicht", "OK", "Warning")
        return
    }
    $dlg = New-Object System.Windows.Forms.OpenFileDialog
    $dlg.Filter    = "Bilddateien (*.jpg;*.jpeg;*.png;*.webp)|*.jpg;*.jpeg;*.png;*.webp"
    $dlg.Title     = "Galeriebild auswaehlen"
    $dlg.Multiselect = $true
    if ($dlg.ShowDialog() -eq "OK") {
        foreach ($f in $dlg.FileNames) {
            if ($script:galeriebilder.Count -ge 10) { break }
            $name = [System.IO.Path]::GetFileName($f)
            if (-not $script:galeriebilder.Contains($f)) {
                $script:galeriebilder.Add($f) | Out-Null
                $lstBilder.Items.Add($name) | Out-Null
            }
        }
        $lblAnzahl.Text = "$($script:galeriebilder.Count) / 10 Bilder"
    }
})

$btnGalerieBildEntfernen.Add_Click({
    if ($lstBilder.SelectedIndex -ge 0) {
        $idx = $lstBilder.SelectedIndex
        $script:galeriebilder.RemoveAt($idx)
        $lstBilder.Items.RemoveAt($idx)
        $lblAnzahl.Text = "$($script:galeriebilder.Count) / 10 Bilder"
    }
})

$btnSpeichern.Add_Click({
    if (-not $script:gewaehlteTitelbild) {
        [System.Windows.Forms.MessageBox]::Show("Bitte ein Titelbild auswaehlen.", "Kein Titelbild", "OK", "Warning")
        return
    }
    if ($txtTitel.Text.Trim() -eq "") {
        [System.Windows.Forms.MessageBox]::Show("Bitte einen Titel eingeben.", "Kein Titel", "OK", "Warning")
        return
    }
    if ($txtText.Text.Trim() -eq "") {
        [System.Windows.Forms.MessageBox]::Show("Bitte eine Beschreibung eingeben.", "Keine Beschreibung", "OK", "Warning")
        return
    }
    try {
        $titelbildPfad = Kopiere-Bild $script:gewaehlteTitelbild

        $galPfade = @()
        foreach ($b in $script:galeriebilder) {
            $galPfade += Kopiere-Bild $b
        }

        if (Test-Path $jsonPath) {
            Copy-Item $jsonPath "$jsonPath.bak" -Force
        }

        $projekte = Lade-Projekte
        $liste = New-Object System.Collections.ArrayList
        foreach ($p in $projekte) { $liste.Add($p) | Out-Null }

        $neuerEintrag = [PSCustomObject]@{
            titel     = $txtTitel.Text.Trim()
            text      = $txtText.Text.Trim()
            titelbild = $titelbildPfad
            bilder    = $galPfade
            vorher    = $chkVorher.Checked
        }
        $liste.Add($neuerEintrag) | Out-Null

        $json = $liste | ConvertTo-Json -Depth 5
        [System.IO.File]::WriteAllText($jsonPath, $json, [System.Text.Encoding]::UTF8)

        $lblStatus.ForeColor = [System.Drawing.Color]::FromArgb(34, 139, 34)
        $lblStatus.Text = "Referenz erfolgreich gespeichert!"

        $txtTitel.Text = ""
        $txtText.Text  = ""
        $txtTitelbildPfad.Text = ""
        $picTitel.Image = $null
        $lblTitelVorschau.Visible = $true
        $script:gewaehlteTitelbild = $null
        $script:galeriebilder.Clear()
        $lstBilder.Items.Clear()
        $lblAnzahl.Text = "0 / 10 Bilder"
        $chkVorher.Checked = $true

    } catch {
        [System.Windows.Forms.MessageBox]::Show("Fehler: $_", "Fehler", "OK", "Error")
    }
})

$btnAbbrechen.Add_Click({ $form.Close() })

[System.Windows.Forms.Application]::EnableVisualStyles()
$form.ShowDialog() | Out-Null
